{
  "name": "quran-mcp",
  "version": "0.1.0",
  "description": "A Model Context Protocol (MCP) server for Quran data — search ayahs, browse surahs, retrieve translations, and more.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "quran-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "quran",
    "islam",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
